###########################################
# IBM Guardium GDP - Central Manager Vars
###########################################

# Copy this file to terraform.tfvars and edit the values in it
# before running "terraform plan" and "terraform apply".

# =====================================================
# AWS Region & Network
# =====================================================

# AWS region where GDP is to be created.
region = "us-east-1"

# ID of the VPC that GDP will be created in.
vpc_id = "vpc-0b88123d60e712fe2"

# Subnet that GDP will be created in.
subnet_id = "subnet-0c82066180e40df72"

# =====================================================
# Guardium Central Manager Deployment
# =====================================================

# AMI type: 'legacy' - for unit-type-specific AMIs or 'unified' - for multi-unit-type AMIs
# When using unified AMI, the system automatically configures the unit type.
ami_type = "legacy"

# AMI image to be used for the GDP machine.
central_manager_ami_id = "ami-0955ca4c9f731cc20"

# AWS instance type to be used for the GDP machine.
central_manager_instance_type = "m6i.2xlarge"

# =====================================================
# SSH Access
# =====================================================

# Name of the key pair used to access GDP on AWS
key_name = "my_rsa_key"

# Path on the computer running this process to the PEM file
pem_file_path = "/home/my-user/.ssh/my_rsa_key.pem"

# =====================================================
# Security Group CIDRs
# =====================================================

# IP addresses that can access the GDP machine.
allowed_cidrs = [
  "10.0.0.0/16",
  "170.225.223.17/32"
]

# Optional custom admin IPs
custom_allowed_cidrs = [
  "129.41.47.4/32"
]

# =====================================================
# Public vs Private IP
# =====================================================

# Should the GDP machine have a public IP address or be
# accessible only through bastion. use true or false
assign_public_ip = false

# =====================================================
# Cloud-Init (optional)
# =====================================================

# Path to Cloud-Init user-data file (e.g., #cloud-config). Relative to examples/central-manager.
# Leave empty to omit. Cloud-Init runs at first boot; Terraform then waits and runs configuration.
#
# For unified AMIs: The module automatically injects 'aggregator: true' and 'license_accepted: true'.
# Your custom config is safely merged without overriding critical fields.
user_data_file = "./user-data.yaml"

# =====================================================
# Shared Secret (for Aggregators/Collectors to register)
# =====================================================

# Shared secret that Aggregators and Collectors will use to register with this Central Manager
shared_secret = "guard"

# =====================================================
# GDP License Keys (optional)
# =====================================================

# AWS Trial Base license. Leave empty to skip automated license installation.
license_base = ""

# Append Trial License. Leave empty to skip automated license installation.
license_append = ""

# =====================================================
# GDP Configuration
# =====================================================

# Domain name
domain = "corp.mycompany.local"

# Timezone
timezone = "America/New_York"

# DNS servers
resolver1 = "8.8.4.4"
resolver2 = "1.1.1.1"

# GDP tags
tags = {
  Environment = "dev"
  Project     = "GuardiumGDP"
  Owner       = "customer@example.com"
  Role        = "CentralManager"
}

# =====================================================
# Instance Naming and Storage (optional)
# =====================================================

# Prefix for instance name tag. Instance number will be appended (e.g., guard-cm-01)
# instance_name_prefix = "guard-cm"

# Size of the root EBS volume in GB (minimum 1500 GB for Central Manager)
# root_volume_size = 1500

# Type of the root EBS volume (gp2, gp3, io1, io2)
# root_volume_type = "gp3"

# Whether to delete the root volume when the instance is terminated
# root_volume_delete_on_termination = true

# =====================================================
# Existing Security Groups (optional)
# =====================================================
# Leave empty to auto-create a new SG or detect existing "guardium-cm-sg"
existing_guardium_cm_sg_id         = ""
existing_guardium_aggregator_sg_id = ""
existing_guardium_collector_sg_id  = ""
